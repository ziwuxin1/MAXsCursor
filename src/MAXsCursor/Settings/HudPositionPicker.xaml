<Window x:Class="MAXsCursor.Settings.HudPositionPicker"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="调整按键显示位置"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Background="Transparent"
        Icon="pack://application:,,,/Assets/cursor.png"
        Topmost="True"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual"
        FontFamily="Microsoft YaHei UI"
        FontSize="12"
        ThemeMode="System"
        MouseLeftButtonDown="OnDragStart">
    <Border CornerRadius="10" Background="#E0202020" Padding="18" BorderBrush="#60FFFFFF" BorderThickness="1">
        <StackPanel>
            <TextBlock x:Name="HintText"
                       Foreground="#CCCCCC" HorizontalAlignment="Center"
                       Margin="0,0,0,12"/>
            <Border Background="#CC101010" BorderBrush="#60FFFFFF" BorderThickness="1"
                    CornerRadius="6" Padding="14,6" HorizontalAlignment="Center"
                    IsHitTestVisible="False">
                <TextBlock x:Name="SampleText" Text="Ctrl+S"
                           Foreground="White" FontFamily="Segoe UI"
                           FontSize="24" FontWeight="SemiBold"/>
            </Border>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                <Button x:Name="CancelButton" Padding="14,4" Margin="0,0,8,0"
                        Click="Cancel_Click" IsCancel="True"/>
                <Button x:Name="OkButton" Padding="14,4"
                        Click="Ok_Click" IsDefault="True"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
