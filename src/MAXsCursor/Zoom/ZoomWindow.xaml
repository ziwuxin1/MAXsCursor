<Window x:Class="MAXsCursor.Zoom.ZoomWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MAXs Cursor Zoom"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="Black"
        Topmost="True"
        Focusable="True"
        WindowStartupLocation="Manual"
        Icon="pack://application:,,,/Assets/cursor.png"
        ThemeMode="Dark"
        Cursor="Cross">
    <Window.Resources>
        <!-- Pure-color swatch button that honors inline Background / BorderBrush /
             BorderThickness. Fluent default ignores those and adds its own chrome. -->
        <Style x:Key="SwatchStyle" TargetType="Button">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid x:Name="RootGrid" ClipToBounds="True">
        <!-- Layer that holds the captured screenshot + the ink strokes.
             Scale and pan transforms are applied together so ink aligns with screen. -->
        <Canvas x:Name="ContentCanvas" IsHitTestVisible="True">
            <Image x:Name="ScreenImage" IsHitTestVisible="False"/>
            <InkCanvas x:Name="Ink" Background="Transparent" EditingMode="Ink"/>
            <!-- Eraser preview. Sits in the same canvas so the scale transform makes it
                 track the actual eraser footprint on screen. Hidden when pen is active. -->
            <Ellipse x:Name="EraserPreview"
                     Width="8" Height="8"
                     Stroke="White" StrokeThickness="1" StrokeDashArray="3,3"
                     Fill="#28FFFFFF"
                     IsHitTestVisible="False"
                     Visibility="Collapsed"/>
        </Canvas>

        <!-- Floating toolbar, stays anchored to the top-center regardless of zoom/pan. -->
        <Border HorizontalAlignment="Center" VerticalAlignment="Top"
                Margin="0,16,0,0"
                Padding="14,8,18,8"
                CornerRadius="10"
                Background="#E01E1E1E"
                BorderBrush="#60FFFFFF"
                BorderThickness="1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="ColorRed"    Style="{StaticResource SwatchStyle}" Width="24" Height="24" Margin="3,0" Click="OnColorClick" Tag="#FF3B30" ToolTip="Red"/>
                    <Button x:Name="ColorOrange" Style="{StaticResource SwatchStyle}" Width="24" Height="24" Margin="3,0" Click="OnColorClick" Tag="#FF9500" ToolTip="Orange"/>
                    <Button x:Name="ColorYellow" Style="{StaticResource SwatchStyle}" Width="24" Height="24" Margin="3,0" Click="OnColorClick" Tag="#FFCC00" ToolTip="Yellow"/>
                    <Button x:Name="ColorGreen"  Style="{StaticResource SwatchStyle}" Width="24" Height="24" Margin="3,0" Click="OnColorClick" Tag="#34C759" ToolTip="Green"/>
                    <Button x:Name="ColorBlue"   Style="{StaticResource SwatchStyle}" Width="24" Height="24" Margin="3,0" Click="OnColorClick" Tag="#007AFF" ToolTip="Blue"/>
                    <Button x:Name="ColorPink"   Style="{StaticResource SwatchStyle}" Width="24" Height="24" Margin="3,0" Click="OnColorClick" Tag="#FF2D55" ToolTip="Pink"/>
                    <Button x:Name="ColorWhite"  Style="{StaticResource SwatchStyle}" Width="24" Height="24" Margin="3,0" Click="OnColorClick" Tag="#FFFFFF" ToolTip="White"/>
                </StackPanel>

                <Separator Width="1" Background="#40FFFFFF" Margin="12,2"/>

                <TextBlock x:Name="ThicknessLabelText" Foreground="White" VerticalAlignment="Center" Opacity="0.85" Margin="4,0,8,0"/>
                <Slider x:Name="ThicknessSlider" Width="120" Minimum="1" Maximum="24" Value="4"
                        SmallChange="1" LargeChange="2"
                        VerticalAlignment="Center"
                        IsMoveToPointEnabled="True"
                        ValueChanged="OnThicknessChanged"/>
                <TextBlock x:Name="ThicknessValueText" Foreground="White" VerticalAlignment="Center" Opacity="0.7" Margin="8,0,0,0" FontSize="12" MinWidth="32"/>

                <Separator Width="1" Background="#40FFFFFF" Margin="12,2"/>

                <Button x:Name="PenButton" MinWidth="64" Height="28" Padding="10,0"
                        Margin="2,0" Click="OnPenClick" ToolTip="Pen (B)"
                        Foreground="White" Background="#30FFFFFF" BorderBrush="#60FFFFFF"/>
                <Button x:Name="EraserButton" MinWidth="64" Height="28" Padding="10,0"
                        Margin="2,0" Click="OnEraserClick" ToolTip="Eraser (E)"
                        Foreground="White" Background="#30FFFFFF" BorderBrush="#60FFFFFF"/>

                <Separator Width="1" Background="#40FFFFFF" Margin="12,2"/>

                <Button x:Name="UndoButton" Content="↶" Width="32" Height="28"
                        Margin="2,0" Click="OnUndo" ToolTip="Undo (Ctrl+Z)"
                        Foreground="White" Background="#30FFFFFF" BorderBrush="#60FFFFFF"/>
                <Button x:Name="ClearButton" MinWidth="64" Height="28" Padding="10,0"
                        Margin="2,0,0,0" Click="OnClear" ToolTip="Clear (C)"
                        Foreground="White" Background="#30FFFFFF" BorderBrush="#60FFFFFF"/>

                <Separator Width="1" Background="#40FFFFFF" Margin="12,2"/>

                <Button x:Name="SaveButton" MinWidth="64" Height="28" Padding="10,0"
                        Margin="2,0" Click="OnSave" ToolTip="Save PNG (Ctrl+S)"
                        Foreground="White" Background="#30FFFFFF" BorderBrush="#60FFFFFF"/>
                <Button x:Name="CopyButton" MinWidth="64" Height="28" Padding="10,0"
                        Margin="2,0,0,0" Click="OnCopy" ToolTip="Copy to clipboard (Ctrl+C)"
                        Foreground="White" Background="#30FFFFFF" BorderBrush="#60FFFFFF"/>

                <Separator Width="1" Background="#40FFFFFF" Margin="12,2"/>

                <Button x:Name="ExitButton" MinWidth="72" Height="28" Padding="10,0"
                        Margin="2,0,0,0" Click="OnExit"
                        Foreground="White" Background="#40FF3B30" BorderBrush="#80FF3B30"/>
            </StackPanel>
        </Border>

        <!-- Tiny legend bottom-left: shortcut summary -->
        <Border HorizontalAlignment="Left" VerticalAlignment="Bottom"
                Margin="16" Padding="12,8"
                CornerRadius="6"
                Background="#C01E1E1E"
                BorderBrush="#40FFFFFF"
                BorderThickness="1">
            <TextBlock x:Name="HintText"
                       Foreground="#DDDDDD" FontSize="11" LineHeight="16"
                       TextWrapping="Wrap" MaxWidth="260"/>
        </Border>
    </Grid>
</Window>
